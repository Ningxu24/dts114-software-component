@startuml
actor Customer
actor Developer
actor Librarian

rectangle "Book Catalog REST Portal" {
  usecase "Search books" as SearchBooks
  usecase "Filter results" as FilterResults
  usecase "Sort results" as SortResults
  usecase "Paginate results" as PaginateResults
  usecase "View book details" as ViewBookDetails

  usecase "Query books API" as QueryBooksApi
  usecase "Validate request" as ValidateRequest
  usecase "Return API errors" as ReturnApiErrors
  usecase "Authenticate API key" as AuthenticateApiKey
  usecase "Enforce rate limits" as EnforceRateLimits

  usecase "Manage books" as ManageBooks
  usecase "Manage authors" as ManageAuthors
  usecase "Manage genres" as ManageGenres
  usecase "Check duplicates" as CheckDuplicates
  usecase "Record audit log" as RecordAuditLog
  usecase "Deactivate records" as DeactivateRecords
}

Customer -- SearchBooks
Customer -- ViewBookDetails

Developer -- QueryBooksApi
Developer -- AuthenticateApiKey
Developer -- EnforceRateLimits

Librarian -- ManageBooks
Librarian -- ManageAuthors
Librarian -- ManageGenres

SearchBooks .> FilterResults : <<include>>
SearchBooks .> SortResults : <<include>>
SearchBooks .> PaginateResults : <<include>>
ViewBookDetails .> SearchBooks : <<extend>>

QueryBooksApi .> ValidateRequest : <<include>>
QueryBooksApi .> PaginateResults : <<include>>
ValidateRequest .> ReturnApiErrors : <<extend>>
QueryBooksApi .> AuthenticateApiKey : <<include>>
QueryBooksApi .> EnforceRateLimits : <<include>>

ManageBooks .> CheckDuplicates : <<include>>
ManageAuthors .> CheckDuplicates : <<include>>
ManageGenres .> CheckDuplicates : <<include>>

ManageBooks .> RecordAuditLog : <<include>>
ManageAuthors .> RecordAuditLog : <<include>>
ManageGenres .> RecordAuditLog : <<include>>

ManageBooks .> DeactivateRecords : <<extend>>
ManageAuthors .> DeactivateRecords : <<extend>>
ManageGenres .> DeactivateRecords : <<extend>>
@enduml