@startuml
skinparam classAttributeIconSize 0

class Book {
  +id: UUID
  +isbn: String
  +title: String
  +author: String
  +description: String
  +price: Decimal
  +stockQty: int
  +publishedAt: Date
  +isActive: boolean
}

class Genre {
  +id: UUID
  +name: String
  +slug: String
}

class User {
  +id: UUID
  +email: String
  +passwordHash: String
  +fullName: String
  +phone: String
  +createdAt: DateTime
  +isActive: boolean
}

class Cart {
  +id: UUID
  +createdAt: DateTime
  +updatedAt: DateTime
}

class Order {
  +id: UUID
  +orderNumber: String
  +status: OrderStatus
  +subtotal: Decimal
  +tax: Decimal
  +shipping: Decimal
  +total: Decimal
  +placedAt: DateTime
}

class OrderItem {
  +id: UUID
  +quantity: int
  +unitPrice: Decimal
  +lineTotal: Decimal
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

' Relationships
Genre "1" <-- "*" Book : belongs to
User "1" *-- "1" Cart : owns
User "1" o-- "*" Order : places

Cart "1" *-- "*" OrderItem : contains
Order "1" *-- "*" OrderItem : includes

Book "1" <-- "*" OrderItem : for
@enduml