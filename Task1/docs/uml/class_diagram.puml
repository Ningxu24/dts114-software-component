@startuml
skinparam classAttributeIconSize 0

class Book {
  +id: UUID
  +title: String
  +description: Text
  +isbn13: String
  +publishedDate: Date
  +availabilityStatus: AvailabilityStatus
  +isActive: Boolean
  +createdAt: DateTime
  +updatedAt: DateTime
}

class Author {
  +id: UUID
  +displayName: String
  +sortName: String
  +bio: Text
  +isActive: Boolean
  +createdAt: DateTime
  +updatedAt: DateTime
}

class Genre {
  +id: UUID
  +name: String
  +slug: String
  +isActive: Boolean
  +createdAt: DateTime
  +updatedAt: DateTime
}

class ApiClient {
  +id: UUID
  +name: String
  +apiKeyHash: String
  +isActive: Boolean
  +rateLimitPerMinute: Int
  +createdAt: DateTime
  +lastUsedAt: DateTime?
}

class AuditLogEntry {
  +id: UUID
  +actorType: ActorType
  +actorId: String
  +action: String
  +entityType: String
  +entityId: UUID
  +beforeJson: Json?
  +afterJson: Json?
  +occurredAt: DateTime
}

enum AvailabilityStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
  DISCONTINUED
}

enum ActorType {
  STAFF
  API_CLIENT
}

' Relationships
Book "0..*" -- "0..*" Author : written by
Book "0..*" -- "0..*" Genre : categorized as

ApiClient "1" *-- "0..*" AuditLogEntry : logs
Book "1" o-- "0..*" AuditLogEntry : changes
Author "1" o-- "0..*" AuditLogEntry : changes
Genre "1" o-- "0..*" AuditLogEntry : changes
@enduml